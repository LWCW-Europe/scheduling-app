# Copy to .env and fill in values before running docker compose

# Site password — leave empty to disable authentication
SITE_PASSWORD=

# HMAC secret for auth cookies — required when SITE_PASSWORD is set
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# HTML injected into the footer right section (optional)
NEXT_PUBLIC_FOOTER_RIGHT_HTML=

# Host port to expose (default: 3000)
HOST_PORT=3000

# Git commit hash baked into the footer at build time (optional)
# Pass via: COMMIT_HASH=$(git rev-parse --short HEAD) docker compose up --build
COMMIT_HASH=
