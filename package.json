{
  "name": "manifest-schedule",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node set-env.js development next dev",
    "build": "next build",
    "start": "node set-env.js production next start",
    "lint": "eslint --max-warnings 0 app db utils",
    "typecheck": "tsc --noEmit",
    "lint-watch": "watchexec -c -w app -w db -w utils \"eslint --fix app db utils\"",
    "dev:test": "node set-env.js development npx playwright test --headed",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "dev:migrate:up": "node set-env.js development drizzle-kit migrate",
    "dev:migrate:status": "node set-env.js development drizzle-kit check",
    "dev:migrate:create": "node set-env.js development drizzle-kit generate",
    "dev:db:reset": "node set-env.js development tsx tests/reset-database.ts"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.3.0",
    "js-cookie": "^3.0.5",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "moment-timezone": "^0.6.1",
    "nanoid": "^5.1.9",
    "next": "^16",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "postcss": "^8.5.10",
    "prettier": "3.8.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "typescript-eslint": "^8.58.2"
  }
}
